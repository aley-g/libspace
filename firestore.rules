rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rooms: everyone can read (student + librarian). Writes need a signed-in Firebase user.
    // The app calls signInAnonymously() on load so mock/demo users still get request.auth.
    match /rooms/{roomId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    // App profile: role + display name for real Firebase email accounts (uid = auth uid).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
